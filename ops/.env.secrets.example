# =============================================================================
# Token RugCheck MCP — Secrets File (Example)
# =============================================================================
# Copy this file to ops/.env.secrets and fill in real values.
# NEVER commit the real secrets file — it is gitignored.
# =============================================================================

# ── Required ──────────────────────────────────────────────────────────────────

# Solana RPC endpoint (Helius, QuickNode, or other provider)
SOLANA_RPC_URL=<YOUR_RPC_URL>

# Buyer/consumer wallet private key (Base58-encoded)
BUYER_PRIVATE_KEY=<YOUR_BASE58_KEY>

# ── Optional ──────────────────────────────────────────────────────────────────

# ag402 prepaid channel signing key (generated during prepaid setup)
AG402_PREPAID_SIGNING_KEY=

# GoPlus Security API credentials (enhances audit depth)
GOPLUS_APP_KEY=
GOPLUS_APP_SECRET=
