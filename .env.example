# =============================================================================
# Token RugCheck MCP — Environment Configuration
# Copy to .env and edit:  cp .env.example .env
# =============================================================================

# --- Service ---
RUGCHECK_HOST=0.0.0.0
RUGCHECK_PORT=8000
RUGCHECK_LOG_LEVEL=info               # debug | info | warning | error

# --- Cache ---
CACHE_TTL_SECONDS=30                  # Audit result cache TTL
CACHE_MAX_SIZE=10000                  # Max entries before LRU eviction

# --- Upstream API Timeouts (seconds) ---
GOPLUS_TIMEOUT_SECONDS=5
RUGCHECK_API_TIMEOUT_SECONDS=5
DEXSCREENER_TIMEOUT_SECONDS=5

# --- GoPlus Authentication (optional, raises rate limit) ---
# Without: ~20-30 req/min anonymous limit
# With:    higher rate limit from GoPlus
# Apply at https://gopluslabs.io/
GOPLUS_APP_KEY=
GOPLUS_APP_SECRET=

# --- ag402 Payment Gateway ---
AG402_PRICE=0.05                      # USDC per audit request
AG402_CHAIN=solana
AG402_TOKEN=USDC
AG402_ADDRESS=<YOUR_SOLANA_WALLET_ADDRESS>
AG402_GATEWAY_PORT=8001

# --- ag402 Mode ---
# X402_MODE:    test (mock payments) | production (real payments)
# X402_NETWORK: mock | localnet | devnet | mainnet
X402_MODE=test
X402_NETWORK=devnet

# --- Solana Wallet (production only) ---
# SOLANA_PRIVATE_KEY=<base58_private_key>
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# --- Consumer Safety Limits (for buyer-side ag402) ---
# X402_DAILY_LIMIT=10.0               # Max daily spend USD
# X402_SINGLE_TX_LIMIT=5.0            # Max per-transaction USD
# X402_PER_MINUTE_LIMIT=2.0           # Max spend per minute
# X402_PER_MINUTE_COUNT=5             # Max transactions per minute
