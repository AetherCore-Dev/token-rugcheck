# =============================================================================
# Token RugCheck MCP — Environment Configuration
# Copy to .env and edit:  cp .env.example .env
# =============================================================================

# --- Service ---
RUGCHECK_HOST=0.0.0.0
RUGCHECK_PORT=8000
RUGCHECK_LOG_LEVEL=info               # debug | info | warning | error

# --- Cache ---
# TTL=3s: anti-rug core — prevents stale data during pool drains.
# Agent bursts within the same second still hit cache (high throughput).
CACHE_TTL_SECONDS=3
CACHE_MAX_SIZE=5000                   # ~5000 JSON reports ≈ tens of MB

# --- Rate Limiting ---
# Free users (direct access, non-loopback): daily request quota.
# Paid users (via ag402 gateway, loopback): per-minute sliding window.
FREE_DAILY_QUOTA=20                   # Max free audit requests per IP per day
PAID_RATE_LIMIT=120                   # Max paid audit requests per IP per minute

# --- Upstream API Timeouts (seconds) ---
# Tuned for 4.5s global response budget (LLM tool-call deadline).
# DexScreener: CDN-backed, fastest — strictest deadline.
# GoPlus:      commercial API, moderate tolerance.
# RugCheck:    community API, most generous.
DEXSCREENER_TIMEOUT_SECONDS=1.5
GOPLUS_TIMEOUT_SECONDS=2.5
RUGCHECK_API_TIMEOUT_SECONDS=3.5

# --- GoPlus Authentication (optional, raises rate limit) ---
# Without: ~20-30 req/min anonymous limit
# With:    higher rate limit from GoPlus
# Apply at https://gopluslabs.io/
GOPLUS_APP_KEY=
GOPLUS_APP_SECRET=

# --- ag402 Payment Gateway ---
AG402_PRICE=0.05                      # USDC per audit request
AG402_CHAIN=solana
AG402_TOKEN=USDC
AG402_ADDRESS=<YOUR_SOLANA_WALLET_ADDRESS>
AG402_GATEWAY_PORT=8001
AG402_GATEWAY_HOST=0.0.0.0            # Gateway bind address (use 0.0.0.0 for Docker)
AG402_TARGET_URL=http://localhost:8000 # Upstream audit server URL (Docker: http://audit-server:8000)

# --- ag402 Mode ---
# X402_MODE:    test (mock payments) | production (real payments)
# X402_NETWORK: mock | localnet | devnet | mainnet
X402_MODE=test
X402_NETWORK=devnet

# --- Solana Wallet (production mode only) ---
# SECURITY WARNING: Never commit your private key to version control.
# Use a dedicated wallet for this service — not your main wallet.
# SOLANA_PRIVATE_KEY must be base58-encoded (88 characters, e.g. 5Jd7...xK9q).
# Generate with: solana-keygen new --no-bip39-passphrase
# Export existing: cat ~/.config/solana/id.json | python -c "import json,sys,base58; print(base58.b58encode(bytes(json.load(sys.stdin))).decode())"
# SOLANA_PRIVATE_KEY=<base58_private_key>
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# --- Consumer Safety Limits (for buyer-side ag402) ---
# X402_DAILY_LIMIT=10.0               # Max daily spend USD
# X402_SINGLE_TX_LIMIT=5.0            # Max per-transaction USD
# X402_PER_MINUTE_LIMIT=2.0           # Max spend per minute
# X402_PER_MINUTE_COUNT=5             # Max transactions per minute
